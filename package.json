{
  "name": "audoria",
  "private": true,
  "packageManager": "pnpm@10.15.1",
  "scripts": {
    "api:dev": "pnpm -C api dev",
    "api:worker": "pnpm -C api worker",
    "gen:sdk": "pnpm -C web gen:sdk",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "web:dev": "pnpm -C web dev",
    "dev": "concurrently \"pnpm api:dev\" \"pnpm api:worker\" \"pnpm web:dev\"",
    "db:generate": "drizzle-kit generate --config=api/drizzle.config.ts",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "@jannchie/eslint-config": "^3.7.8",
    "@unocss/eslint-plugin": "^66.6.8",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.2.0",
    "typescript": "^6.0.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3", "sharp", "ytdlp-nodejs", "esbuild", "onnxruntime-node", "protobufjs", "vue-demi"]
  }
}
