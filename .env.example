PORT=8787

# Database
DB_TYPE=sqlite
DB_PATH=./api/data/audoria.sqlite
#
# Use external Cloudflare D1 from Docker when needed:
# D1_ACCOUNT_ID=your-cloudflare-account-id
# D1_DATABASE_ID=your-d1-database-id
# D1_API_TOKEN=your-cloudflare-api-token
# D1_API_BASE_URL=https://api.cloudflare.com/client/v4

# Storage
STORAGE_BACKEND=s3
S3_BUCKET=your-r2-bucket
S3_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
S3_REGION=auto
S3_ACCESS_KEY_ID=your-r2-access-key-id
S3_SECRET_ACCESS_KEY=your-r2-secret-access-key
S3_FORCE_PATH_STYLE=false
#
# Use filesystem storage only for local experiments:
# STORAGE_FS_ROOT=./api/data/storage

VITE_API_BASE=http://localhost:8787/api/v1

MUSICDL_SOURCES=NeteaseMusicClient,QQMusicClient,KuwoMusicClient,MiguMusicClient,JamendoMusicClient
MUSICDL_URL_SOURCES=Bilibili,Youtube
MUSICDL_SEARCH_TIMEOUT_MS=30000
MUSICDL_DOWNLOAD_TIMEOUT_MS=180000

IMPORT_CANDIDATE_TTL_MS=1800000
IMPORT_WORKER_POLL_MS=3000

SECRET_KEY=replace-with-a-long-random-string
