{
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "worker": "tsx watch src/worker.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:worker": "node dist/worker.js",
    "cf:dev": "wrangler dev",
    "cf:deploy": "wrangler deploy",
    "cf:db:create": "wrangler d1 create audoria-db",
    "cf:db:migrate": "wrangler d1 execute audoria-db --file=migrations/001_create_tables.sql",
    "backfill:cover-masks": "tsx scripts/backfill-cover-masks.ts",
    "backfill:cover-thumbhashes": "tsx scripts/backfill-cover-thumbhashes.ts",
    "backfill:duration": "tsx scripts/backfill-duration.ts",
    "backfill:source-identifier": "tsx scripts/backfill-source-identifier.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1031.0",
    "@hono/node-server": "^1.19.14",
    "@hono/swagger-ui": "^0.6.1",
    "@hono/zod-openapi": "^1.3.0",
    "@huggingface/transformers": "^4.1.0",
    "@jannchie/mdl-core": "0.4.0",
    "@jannchie/mdl-sdk": "0.4.0",
    "@scalar/hono-api-reference": "^0.10.8",
    "better-sqlite3": "^12.9.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.14",
    "sharp": "^0.34.5",
    "thumbhash": "^0.1.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
